# ===== LOCAL LLM (Ollama) =====
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=90

# ===== AZURE AI FOUNDRY — FOUNDRY IQ =====
# Get from: Azure Portal → Your Search Service → Keys
AZURE_SEARCH_ENDPOINT=https://<your-search-name>.search.windows.net
AZURE_SEARCH_KEY=<your-primary-admin-key>
AZURE_SEARCH_INDEX=narrative-templates
AZURE_KNOWLEDGE_BASE_NAME=narraseed-kb

# ===== DEV SETTINGS =====
DEBUG=True
PORT=8000
LOG_LEVEL=INFO
